# App-Default-Provider ist llama_cpp_openai (lokaler llama-server). Ollama ist
# Legacy/Fallback und muss explizit gesetzt werden. Dieses Docker-Beispiel setzt
# LLM_PROVIDER=ollama bewusst, weil der Compose-Stack Ollama (nicht llama-server)
# mitbringt. Fuer den llama.cpp-Default: LLM_PROVIDER leer lassen + Server starten
# (siehe docs/performance/llamacpp-opt-in-stability.md) und ggf.:
#   LLAMA_CPP_BASE_URL=http://127.0.0.1:8088/v1
#   LLAMA_CPP_MODEL=gemma-3n-e4b
OLLAMA_URL=http://host.docker.internal:11434
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:12b
OLLAMA_TIMEOUT_SEC=300
OLLAMA_TEMPERATURE=0.6
OLLAMA_NUM_CTX=32768
OLLAMA_SEED=

